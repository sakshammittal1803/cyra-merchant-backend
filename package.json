{
  "name": "merchant-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server-demo.ts",
    "dev:full": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server-demo.js",
    "start:prod": "NODE_ENV=production node dist/server-demo.js",
    "vercel-build": "echo 'No build needed - Vercel will use TypeScript directly'",
    "migrate": "node -r ts-node/register src/config/migrate.ts",
    "test:features": "bash test-production-features.sh",
    "logs:combined": "tail -f logs/combined-*.log",
    "logs:error": "tail -f logs/error-*.log",
    "logs:analyze": "cat logs/combined-*.log | grep '\"level\":\"error\"' | tail -20",
    "health": "curl http://localhost:5000/health",
    "pm2:start": "pm2 start dist/server-demo.js --name merchant-backend",
    "pm2:stop": "pm2 stop merchant-backend",
    "pm2:restart": "pm2 restart merchant-backend",
    "pm2:logs": "pm2 logs merchant-backend",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.0",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^9.0.8",
    "@vercel/node": "^5.7.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
